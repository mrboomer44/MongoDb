@model MongoDb.Dtos.FeatureDto.CreateFeatureDto

@{
    ViewData["Title"] = "CreateFeature";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Yeni Özellik Ekle</h4>

            <form method="post" class="forms-sample">

                <div class="form-group">
                    <label>Özellik Başlığı</label>
                    <input type="text"
                           class="form-control"
                           asp-for="Title"
                           placeholder="Özellik Başlığını Giriniz">
                </div>

                <div class="form-group">
                    <label>Özellik Açıklaması</label>
                    <textarea class="form-control"
                              asp-for="Description"
                              rows="4"
                              placeholder="Özellik Açıklamasını Giriniz">
                    </textarea>
                </div>

                <div class="form-group">
                    <label>Görsel URL</label>
                    <input type="text"
                           class="form-control"
                           asp-for="ImageUrl"
                           placeholder="https://...">
                </div>

                <button type="submit" class="btn btn-primary mr-2">
                    Kaydet
                </button>

                <a href="/Feature/FeatureList"
                   class="btn btn-light">
                    İptal
                </a>

            </form>
        </div>
    </div>
</div>