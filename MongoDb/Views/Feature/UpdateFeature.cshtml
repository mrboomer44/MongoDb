@model MongoDb.Dtos.FeatureDto.GetFeatureByIdDto
@{
    ViewData["Title"] = "UpdateFeature";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Özellik Güncelleme Sayfası</h4>

            <form method="post" class="forms-sample">
                <input type="hidden" asp-for="FeatureId" />

                <div class="form-group">
                    <label>Özellik Başlığı</label>
                    <input type="text" class="form-control" asp-for="Title" placeholder="Özellik Başlığı">
                </div>

                <div class="form-group">
                    <label>Özellik Açıklaması</label>
                    <textarea class="form-control" asp-for="Description" rows="4" placeholder="Özellik Açıklaması"></textarea>
                </div>

                <div class="form-group">
                    <label>Görsel URL</label>
                    <input type="text" class="form-control" asp-for="ImageUrl" placeholder="https://...">
                </div>

                <button type="submit" class="btn btn-primary mr-2">
                    <i class="typcn typcn-tick"></i> Güncelle
                </button>

                <a href="/Feature/FeatureList" class="btn btn-light">
                    <i class="typcn typcn-times"></i> İptal
                </a>
            </form>
        </div>
    </div>
</div>
