@model List<MongoDb.Dtos.SubscribeDto.ResultSubscribeDto>
@{
    ViewData["Title"] = "Aboneler";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    int i = 0;
}

<div class="row mb-4">
    <div class="col-md-4 stretch-card grid-margin">
        <div class="card bg-gradient-primary text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-white-50 mb-2">Toplam Abone</h6>
                        <h2 class="mb-0 text-white">@Model.Count</h2>
                    </div>
                    <i class="typcn typcn-mail" style="font-size: 48px; opacity: 0.3;"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="card-title mb-0">Abone Listesi</h4>
            </div>
            <div class="table-responsive pt-3">
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>E-posta</th>
                            <th>Abone Tarihi</th>
                            <th class="text-center">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            i++;
                            <tr>
                                <td><span class="badge badge-light">@i</span></td>
                                <td><strong>@item.Email</strong></td>
                                <td>@item.SubscribeDate.ToString("dd.MM.yyyy HH:mm")</td>
                                <td class="text-center">
                                    <a href="/Subscribe/DeleteSubscribe/@item.SubscribeId"
                                       class="btn btn-inverse-danger btn-sm"
                                       onclick="return confirm('Bu aboneyi silmek istediğinize emin misiniz?')"
                                       title="Sil">
                                        <i class="typcn typcn-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
