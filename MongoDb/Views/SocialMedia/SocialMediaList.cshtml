@model List<MongoDb.Dtos.SocialMediaDto.ResultSocialMediaDto>
@{
    ViewData["Title"] = "Sosyal Medya";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="card-title mb-0">Sosyal Medya Linkleri</h4>
                @if (!Model.Any())
                {
                    <a href="/SocialMedia/CreateSocialMedia" class="btn btn-inverse-success btn-fw">
                        <i class="typcn typcn-plus"></i> İlk Veriyi Ekle
                    </a>
                }
                else
                {
                    <a href="/SocialMedia/UpdateSocialMedia" class="btn btn-inverse-warning btn-fw">
                        <i class="typcn typcn-edit"></i> Güncelle
                    </a>
                }
            </div>
            @if (Model.Any())
            {
                var item = Model.First();
                <table class="table table-bordered">
                    <tr><th>Facebook</th><td>@item.Facebook</td></tr>
                    <tr><th>Twitter</th><td>@item.Twitter</td></tr>
                    <tr><th>Youtube</th><td>@item.Youtube</td></tr>
                    <tr><th>Instagram</th><td>@item.Instagram</td></tr>
                    <tr><th>LinkedIn</th><td>@item.LinkedIn</td></tr>
                </table>
            }
            else
            {
                <div class="alert alert-warning">Henüz sosyal medya verisi eklenmemiş.</div>
            }
        </div>
    </div>
</div>