@model MongoDb.Dtos.OrderDto.GetOrderByIdDto
@{
    ViewData["Title"] = "Sipariş Detayı";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="col-lg-8 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="card-title mb-0">Sipariş Detayı</h4>
                <a href="/Order/OrderList" class="btn btn-light btn-sm">
                    <i class="typcn typcn-arrow-left"></i> Geri Dön
                </a>
            </div>
            <table class="table table-bordered">
                <tr><th>Müşteri Adı</th><td>@Model.CustomerName</td></tr>
                <tr><th>E-posta</th><td>@Model.Email</td></tr>
                <tr><th>Telefon</th><td>@Model.Phone</td></tr>
                <tr><th>Adres</th><td>@Model.Address</td></tr>
                <tr><th>Posta Kodu</th><td>@Model.ZipCode</td></tr>
                <tr><th>Ürün</th><td>@Model.ProductName</td></tr>
                <tr><th>Sipariş Tarihi</th><td>@Model.OrderDate.ToString("dd.MM.yyyy HH:mm")</td></tr>
            </table>
        </div>
    </div>
</div>
