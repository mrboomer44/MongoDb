@model List<MongoDb.Dtos.FaqDto.ResultFaqDto>

<div class="container" id="faq">
    <div class="about-inline text-center">
        <h3>Sıkça Sorulan Sorular </h3>
    </div>
</div>

<div class="container">
    <div class="row">
        <div class="col-md-6 col-sm-6">
            <div class="faq">
                @foreach (var item in Model.Take(Model.Count / 2 + Model.Count % 2))
                {
                    <h4><span>~</span> @item.Question</h4>
                    <p>@item.Answer</p>
                }
            </div>
        </div>
        <div class="col-md-6 col-sm-6">
            <div class="faq">
                @foreach (var item in Model.Skip(Model.Count / 2 + Model.Count % 2))
                {
                    <h4><span>~</span> @item.Question</h4>
                    <p>@item.Answer</p>
                }
            </div>
        </div>
    </div>
    <div class="space100"></div>
</div>