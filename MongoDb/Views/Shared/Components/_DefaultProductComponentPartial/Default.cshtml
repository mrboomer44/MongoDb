@model List<MongoDb.Dtos.ProductDto.ResultProductDto>

<div id="explore" class="elements-content">
    <div class="container">
        <div class="about-inline text-center">
            <h3>Menülerdeki Lezeetli Ürünlerimiz </h3>
            <p>
                Lorem ipsum dolor sit amet, consectetur adipiscing elit. Etiam et purus a odio finibus bibendum in sit amet leo. Mauris feugiat erat tellus. Far far away, behind the word mountains, far from the countries Vokalia and Consonantia, there
                live the blind texts. Separated they live in Bookmarksgrove.
            </p>
        </div>
        <div class="row">
            @foreach (var item in Model)
            {
            <div class="col-md-4">
                <div class="card card-product">
                    <div class="img-wrap"><img src="@item.ImageUrl" alt="img"></div>
                    <div class="info-wrap">
                        <h4 class="title">@item.ProductName</h4>
                        <p class="desc"> Zaman: @item.TotlalTime DK  </p>
                        <div class="price-wrap h3">
                            <span class="price-new">$ @item.Price</span> <del class="price-old">$ @item.OldPrice</del>
                        </div>
                    </div>
                    <div class="bottom-wrap">
                        <a href="#" class="btn btn-sm btn-primary float-right"
                           data-toggle="modal"
                           data-target="#modalContactForm"
                           onclick="setOrderProduct('@item.ProductName')">Sipariş ver</a>
                    </div>
                </div>
            </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="modalContactForm" tabindex="-1" role="dialog" data-toggle="myModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header text-center">

                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                <div class="cf2-wrap">

                    <h2>Make Your Order Now!</h2>

                    <div class="clearfix space40"></div>
                    <form class="positioned" name="sentMessage" id="contactForm"
                          asp-controller="Order" asp-action="CreateOrder" method="post">
                        <div class="row">

                            <div class="col-md-6 col-sm-6">
                                <input name="CustomerName" id="senderName" placeholder="Your Name" required type="text">
                            </div>
                            <div class="col-md-6 col-sm-6">
                                <input name="Email" id="senderEmail" placeholder="Email Address" required type="email">
                            </div>
                        </div>

                        <input name="Address" id="address" placeholder="Address" required type="text">

                        <input name="ZipCode" placeholder="Zip Code" required type="text">

                        <input name="Phone" placeholder="Mobile No." required type="text">

                        <input type="text" id="productDisplay" placeholder="Seçilen Ürün" readonly style="background:#f5f5f5; cursor:default;">
                        <input type="hidden" name="ProductName" id="productSelect">

                        <button type="submit" class="btn btn-primary btn-ico">Send Message<i class="fa fa-paper-plane-o"></i></button>
                    </form>
                    <div id="sendingMessage" class="statusMessage">
                        <p><i class="fa fa-spin fa-cog"></i> Sending your message. Please wait...</p>
                    </div>
                    <div id="successMessage" class="successmessage">
                        <p><span class="success-ico"></span> Thanks for sending your message! We'll get back to you shortly.</p>
                    </div>
                    <div id="failureMessage" class="errormessage">
                        <p><span class="error-ico"></span> There was a problem sending your message. Please try again.</p>
                    </div>
                    <div id="incompleteMessage" class="statusMessage">
                        <p><i class="fa fa-warning"></i> Please complete all the fields in the form before sending.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function setOrderProduct(productName) {
        document.getElementById('productSelect').value = productName;
        document.getElementById('productDisplay').value = productName;
    }
</script>