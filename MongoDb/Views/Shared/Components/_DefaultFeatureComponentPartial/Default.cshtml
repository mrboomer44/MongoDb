@model MongoDb.Dtos.FeatureDto.ResultFeatureDto

<div class="intro intro3" style="background-image: url('@Model.ImageUrl'); background-size: cover; background-position: center; background-repeat: no-repeat;">
    <div class="container">
        <div class="row center-content">
            <div class="col-md-5 col-sm-6">
                <h3>@Model.Title</h3>
                <p>@Model.Description</p>
                <div class="space30"></div>
                <div class="dual-btn">
                    <a href="#explore" class="btn btn-lg btn-primary page-scroll">Order Now <span class="fa fa-shopping-basket"></span></a> &nbsp; &nbsp;
                    <a href="#about" class="btn btn-lg btn-default btn-border page-scroll">Learn More <i class=" ilmosys-arrow-right"></i></a>
                </div>

            </div>
            <div class="col-md-7 col-sm-6 no-padding">
            </div>
        </div>
    </div>
</div>