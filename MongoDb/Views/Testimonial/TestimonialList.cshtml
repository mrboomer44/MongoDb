@model List<MongoDb.Dtos.TestimonialDto.ResultTestimonialDto>
@{
    ViewData["Title"] = "Referanslar";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    int i = 0;
}

<div class="row mb-4">
    <div class="col-md-4 stretch-card grid-margin">
        <div class="card bg-gradient-primary text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-white-50 mb-2">Toplam Referans</h6>
                        <h2 class="mb-0 text-white">@Model.Count</h2>
                    </div>
                    <i class="typcn typcn-user-outline" style="font-size: 48px; opacity: 0.3;"></i>
                </div>
            </div>
        </div> 
    </div>
</div>

<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="card-title mb-0">Referanslar Listesi</h4>
                <a href="/Testimonial/CreateTestimonial/" class="btn btn-inverse-info btn-fw">
                    <i class="typcn typcn-plus"></i> Yeni Referans Girişi
                </a>
            </div>

            <div class="table-responsive pt-3">
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Referans Adı</th>
                            <th>Mesleği</th>
                            <th>Görsel</th>
                            <th>Yorum</th>
                            <th class="text-center">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            ++i;
                            <tr>
                                <td><span class="badge badge-light">@i</span></td>
                                <td><strong>@item.NameSurnama</strong></td>
                                <td>@item.Position</td>
                                <td><img src="@item.ImageUrl" style="width:60px; height:60px; object-fit:cover; border-radius:50%;" /></td>
                                <td>@item.Description</td>
                                <td class="text-center">
                                    <a href="/Testimonial/UpdateTestimonial/@item.TestimonialId" class="btn btn-inverse-warning btn-sm" title="Güncelle">
                                        <i class="typcn typcn-edit"></i>
                                    </a>
                                    <a href="/Testimonial/DeleteTestimonial/@item.TestimonialId"
                                       class="btn btn-inverse-danger btn-sm"
                                       onclick="return confirm('Silmek istediğinize emin misiniz?')"
                                       title="Sil">
                                        <i class="typcn typcn-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
