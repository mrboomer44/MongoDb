@model List<MongoDb.Dtos.AboutSection2Dto.ResultAboutSection2Dto>
@{
    ViewData["Title"] = "Hakkımızda Bölüm 2";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="card-title mb-0">Hakkımızda Bölüm 2</h4>
                @if (!Model.Any())
                {
                    <a href="/AboutSection2/CreateAboutSection2" class="btn btn-inverse-success btn-fw">
                        <i class="typcn typcn-plus"></i> İlk Veriyi Ekle
                    </a>
                }
                else
                {
                    <a href="/AboutSection2/UpdateAboutSection2" class="btn btn-inverse-warning btn-fw">
                        <i class="typcn typcn-edit"></i> Güncelle
                    </a>
                }
            </div>
            @if (Model.Any())
            {
                var item = Model.First();
                <div class="row">
                    <div class="col-md-6">
                        <table class="table table-bordered">
                            <tr><th style="width:120px">Başlık</th><td>@item.Title</td></tr>
                            <tr><th>Açıklama</th><td style="word-break:break-word; white-space:pre-wrap;">@item.Description</td></tr>
                            <tr><th>Görsel URL</th><td style="word-break:break-all;">@item.ImageUrl</td></tr>
                        </table>
                    </div>
                    <div class="col-md-6 text-center">
                        <img src="@item.ImageUrl" style="max-width:100%; max-height:250px; object-fit:cover; border-radius:10px;" />
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-warning">Henüz veri eklenmemiş.</div>
            }
        </div>
    </div>
</div>