@model List<MongoDb.Dtos.FaqDto.ResultFaqDto>
@{
    ViewData["Title"] = "SSS Listesi";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    int i = 0;
}

<div class="row mb-4">
    <div class="col-md-4 stretch-card grid-margin">
        <div class="card bg-gradient-primary text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-white-50 mb-2">Toplam Soru</h6>
                        <h2 class="mb-0 text-white">@Model.Count</h2>
                    </div>
                    <i class="typcn typcn-info-large" style="font-size: 48px; opacity: 0.3;"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="card-title mb-0">Sık Sorulan Sorular</h4>
                <a href="/Faq/CreateFaq" class="btn btn-inverse-info btn-fw">
                    <i class="typcn typcn-plus"></i> Yeni Soru Ekle
                </a>
            </div>
            <div class="table-responsive pt-3">
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Soru</th>
                            <th>Cevap</th>
                            <th class="text-center">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            i++;
                            <tr>
                                <td><span class="badge badge-light">@i</span></td>
                                <td><strong>@item.Question</strong></td>
                                <td>@item.Answer</td>
                                <td class="text-center">
                                    <a href="/Faq/UpdateFaq/@item.FaqId"
                                       class="btn btn-inverse-warning btn-sm" title="Güncelle">
                                        <i class="typcn typcn-edit"></i>
                                    </a>
                                    <a href="/Faq/DeleteFaq/@item.FaqId"
                                       class="btn btn-inverse-danger btn-sm"
                                       onclick="return confirm('Silmek istediğinize emin misiniz?')"
                                       title="Sil">
                                        <i class="typcn typcn-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>