@model MongoDb.Dtos.AboutListDto.CreateAboutListDto
@{
    ViewData["Title"] = "Yeni Madde Ekle";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Yeni Madde Ekle</h4>
            <form method="post" class="forms-sample">
                <div class="form-group">
                    <label>Başlık</label>
                    <input type="text" class="form-control" asp-for="Title" placeholder="Başlık Giriniz">
                </div>
                <button type="submit" class="btn btn-primary mr-2">Kaydet</button>
                <a href="/AboutList/AboutListList" class="btn btn-light">İptal</a>
            </form>
        </div>
    </div>
</div>